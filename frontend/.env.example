# ZKCred Environment Variables
# Copy this file to .env.local and fill in your values

# ============ AWS Bedrock ============
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# ============ Starknet Network ============
STARKNET_RPC_URL=https://rpc.starknet-testnet.lava.build/rpc/v0_8
NEXT_PUBLIC_STARKNET_NETWORK=sepolia

# ============ Contract Addresses ============
# Fill these after deploying contracts
CREDENTIAL_REGISTRY_ADDRESS=0x...
CREDENTIAL_VERIFIER_ADDRESS=0x...

# ============ Server Account ============
# This account pays for gas on credential issuance
# Get testnet STRK from: https://starknet-faucet.vercel.app/
STARKNET_PRIVATE_KEY=your_private_key_here
STARKNET_ACCOUNT_ADDRESS=your_account_address_here

# ============ Redis (Chat Sessions) ============
# Optional - if not set, chat sessions won't be persisted
# For production, use a managed Redis like Upstash or AWS ElastiCache
REDIS_URL=redis://localhost:6379

# ============ Oracle Config ============
# Mock tiers for demo addresses (comma-separated address:tier pairs)
# Example: MOCK_TIERS=bc1qaddr1:3,bc1qaddr2:2,bc1qaddr3:1
MOCK_TIERS=

# ============ App Config ============
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_EXPLORER_URL=https://sepolia.starkscan.co
