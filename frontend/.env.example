# ZKCred Environment Variables
# Copy this file to .env.local and fill in your values

# ============ AWS Bedrock ============
# Required for AI chat agent (credential issuance)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# ============ Starknet Network ============
STARKNET_RPC_URL=https://rpc.starknet-testnet.lava.build/rpc/v0_8
NEXT_PUBLIC_STARKNET_NETWORK=sepolia

# ============ Contract Addresses ============
# Fill these after deploying contracts (node contracts/scripts/deploy.js)
CREDENTIAL_REGISTRY_ADDRESS=0x...
CREDENTIAL_VERIFIER_ADDRESS=0x...
CREDENTIAL_MERKLE_ADDRESS=0x...
RANGE_PROOF_VERIFIER_ADDRESS=0x...
BADGE_NFT_ADDRESS=0x...
NEXT_PUBLIC_BADGE_NFT_ADDRESS=0x...

# ============ Server Account ============
# This account pays for gas on credential issuance
# Get testnet STRK from: https://starknet-faucet.vercel.app/
STARKNET_PRIVATE_KEY=your_private_key_here
STARKNET_ACCOUNT_ADDRESS=your_account_address_here

# ============ Redis ============
# Required for API key storage, rate limiting, and chat session persistence
# For local dev: redis://localhost:6379
# For production: use a managed Redis (Upstash, AWS ElastiCache, etc.)
REDIS_URL=redis://localhost:6379

# ============ Oracle Config ============
# Mock tiers for demo addresses (comma-separated address:tier pairs)
# Allows testing without real Bitcoin balance lookups
# Example: MOCK_TIERS=bc1qaddr1:3,bc1qaddr2:2,bc1qaddr3:1
MOCK_TIERS=

# ============ Connector OAuth / API Keys ============
# GitHub OAuth: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
NEXT_PUBLIC_GITHUB_CLIENT_ID=

# Steam Web API: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

# Strava OAuth: https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Codeforces OIDC: https://codeforces.com/settings/api
CODEFORCES_CLIENT_ID=
CODEFORCES_CLIENT_SECRET=
NEXT_PUBLIC_CODEFORCES_CLIENT_ID=

# ============ Discord Bot (Optional) ============
# Set these to run the Discord bot alongside the Next.js server
# If DISCORD_TOKEN is not set, the bot is disabled (server runs normally)
# Get these from: https://discord.com/developers/applications
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
# API key for the bot to call ZKCred API (generate from Settings page)
ZKCRED_DISCORD_API_KEY=

# ============ App Config ============
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_EXPLORER_URL=https://sepolia.starkscan.co
