# ZKCred Environment Variables
# Copy this file to .env.local and fill in your values

# ============ AWS Bedrock ============
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# ============ Starknet Network ============
STARKNET_RPC_URL=https://starknet-sepolia.public.blastapi.io/rpc/v0_7
NEXT_PUBLIC_STARKNET_NETWORK=sepolia

# ============ Contract Addresses ============
# Fill these after deploying contracts
CREDENTIAL_REGISTRY_ADDRESS=0x...
CREDENTIAL_VERIFIER_ADDRESS=0x...

# ============ Server Account ============
# This account pays for gas on credential issuance
# Get testnet ETH from: https://starknet-faucet.vercel.app/
STARKNET_ACCOUNT_ADDRESS=0x...
STARKNET_PRIVATE_KEY=0x...

# ============ App Config ============
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_EXPLORER_URL=https://sepolia.starkscan.co
